# Database
DATABASE_URL=postgresql+asyncpg://watchdog:watchdog@localhost:5433/watchdog
TEST_DATABASE_URL=postgresql+asyncpg://watchdog:watchdog@localhost:5433/watchdog_test

# Security
SECRET_KEY=change-me-in-production-use-32-random-chars
API_KEY_HEADER=X-API-Key
# Comma-separated list of valid API keys (in prod, store in DB)
BOOTSTRAP_API_KEYS=dev-key-1234,test-key-5678

# App
APP_ENV=development
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# Anomaly Detection
ANOMALY_WINDOW_MINUTES=5
ANOMALY_SPIKE_MULTIPLIER=3.0
ALERT_COOLDOWN_MINUTES=10

# Dashboard
DASHBOARD_REFRESH_SECONDS=10
